# Copy to .env and fill in values. Never commit .env to git.

# ── Required ─────────────────────────────────────────────────────────────────

# Password for the web editor (single shared password)
WIKI_PASSWORD=change-me

# Secret used to sign JWT tokens — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-too

# Absolute path to the wiki-hpv repo on this server
WIKI_REPO_PATH=/home/ubuntu/wiki-hpv

# Claude Code must be installed and already authenticated on this server.
# Run `claude login` once as the same user that runs start.sh — credentials
# are stored in ~/.claude/ and picked up automatically. No API key needed.


# ── Optional tuning ──────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins (default: * — restrict in production)
CORS_ORIGINS=*

# JWT expiry in hours (default: 24)
JWT_EXPIRY_HOURS=24

# Public path the app is served under. Leave as / when it's at the domain root.
# When reverse-proxied under a sub-path, set this to match the nginx location
# (no trailing slash needed), e.g. BASE_PATH=/chathpv/wiki — otherwise the
# browser requests style.css/app.js from the wrong place and only bare HTML loads.
# BASE_PATH=/

# Where the who-edited-what audit trail is written (JSONL, append-only).
# Default: edits.log next to the app. Set an absolute path to keep it elsewhere.
# EDIT_LOG_PATH=/home/ubuntu/wiki-hpv/edits.log
